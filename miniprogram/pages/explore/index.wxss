page {
  min-height: 100%;
  background: #F8F7F4;
}

.page {
  box-sizing: border-box;
  color: #1F2937;
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 34rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
}

.topbar {
  align-items: center;
  display: flex;
  flex-direction: row;
  flex-shrink: 0;
  padding: 4rpx 0 22rpx;
  position: relative;
}

.top-main {
  align-items: center;
  display: flex;
  flex: 1;
  min-width: 0;
  padding-right: 0;
  width: 100%;
}

.top-leaf {
  height: 42rpx;
  margin-right: 14rpx;
  width: 42rpx;
}

.top-title {
  color: #1F2937;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.top-text {
  flex: 1;
  min-width: 0;
}

.top-subtitle {
  color: rgba(31, 41, 55, 0.52);
  font-size: 22rpx;
  line-height: 32rpx;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-actions {
  display: flex;
  flex-shrink: 0;
  gap: 14rpx;
  margin-left: 16rpx;
}

.top-action {
  align-items: center;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(61, 189, 147, 0.24);
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  flex: 0 0 58rpx;
  font-size: 0;
  height: 58rpx;
  justify-content: center;
  line-height: 58rpx;
  margin: 0;
  max-width: 58rpx;
  min-width: 0;
  overflow: hidden;
  padding: 0;
  width: 58rpx;
}

.primary-action {
  background: rgba(61, 189, 147, 0.12);
}

.top-action-icon {
  height: 32rpx;
  width: 32rpx;
}

.top-action::after {
  border: none;
}

.journal {
  box-sizing: border-box;
  flex: 1;
  min-height: 0;
  padding: 18rpx 0 32rpx;
}

.record {
  margin-bottom: 44rpx;
}

.user-note {
  padding: 0 6rpx;
}

.note-label {
  color: rgba(31, 41, 55, 0.42);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 32rpx;
  margin-bottom: 10rpx;
}

.note-text {
  color: #1F2937;
  font-size: 34rpx;
  line-height: 56rpx;
  white-space: pre-wrap;
}

.ai-card {
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(31, 41, 55, 0.06);
  border-radius: 8rpx;
  box-shadow: 0 16rpx 38rpx rgba(31, 41, 55, 0.045);
  box-sizing: border-box;
  padding: 34rpx 32rpx;
}

.card-title {
  color: #1F2937;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 52rpx;
  margin-bottom: 26rpx;
}

.explore-section {
  margin-top: 26rpx;
}

.first-section {
  margin-top: 0;
}

.section-label {
  color: rgba(35, 119, 93, 0.72);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 32rpx;
  margin-bottom: 8rpx;
}

.section-text {
  color: rgba(31, 41, 55, 0.76);
  font-size: 30rpx;
  line-height: 52rpx;
  white-space: pre-wrap;
}

.reality-text-block {
  margin-top: 12rpx;
}

.reality-text-block:first-child {
  margin-top: 0;
}

.reality-notice {
  background: rgba(248, 247, 244, 0.82);
  border: 1rpx solid rgba(31, 41, 55, 0.06);
  border-radius: 8rpx;
  color: rgba(31, 41, 55, 0.52);
  font-size: 24rpx;
  line-height: 38rpx;
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  white-space: pre-wrap;
}

.reality-perspective {
  color: rgba(31, 41, 55, 0.76);
  font-size: 30rpx;
  line-height: 52rpx;
  margin-top: 26rpx;
  white-space: pre-wrap;
}

.reality-table-block,
.reality-bar-block {
  margin-top: 22rpx;
}

.reality-block-title {
  color: #1F2937;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 38rpx;
  margin-bottom: 12rpx;
}

.reality-block-unit {
  color: rgba(31, 41, 55, 0.42);
  font-size: 22rpx;
  line-height: 32rpx;
  margin: -4rpx 0 14rpx;
}

.reality-table-scroll {
  width: 100%;
}

.reality-table {
  border: 1rpx solid rgba(31, 41, 55, 0.08);
  border-bottom: none;
  border-radius: 8rpx;
  display: inline-block;
  min-width: 640rpx;
  overflow: hidden;
}

.reality-row {
  border-bottom: 1rpx solid rgba(31, 41, 55, 0.08);
  display: flex;
}

.reality-head {
  background: rgba(61, 189, 147, 0.08);
}

.reality-cell {
  border-right: 1rpx solid rgba(31, 41, 55, 0.07);
  box-sizing: border-box;
  color: rgba(31, 41, 55, 0.72);
  flex: 1;
  font-size: 24rpx;
  line-height: 36rpx;
  min-width: 190rpx;
  padding: 16rpx 18rpx;
  white-space: normal;
}

.reality-cell:last-child {
  border-right: none;
}

.reality-head .reality-cell {
  color: rgba(35, 119, 93, 0.82);
  font-weight: 700;
}

.bar-item {
  margin-top: 18rpx;
}

.bar-item:first-child {
  margin-top: 0;
}

.bar-meta {
  align-items: baseline;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 10rpx;
}

.bar-label {
  color: rgba(31, 41, 55, 0.78);
  flex-shrink: 0;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.bar-note {
  color: rgba(31, 41, 55, 0.44);
  flex: 1;
  font-size: 22rpx;
  line-height: 32rpx;
  text-align: right;
}

.bar-track {
  background: rgba(61, 189, 147, 0.1);
  border-radius: 999rpx;
  height: 14rpx;
  overflow: hidden;
  width: 100%;
}

.bar-fill {
  background: linear-gradient(90deg, #6FD3B0, #3DBD93);
  border-radius: 999rpx;
  height: 100%;
  min-width: 12rpx;
}

.source-list {
  border-top: 1rpx solid rgba(31, 41, 55, 0.07);
  margin-top: 24rpx;
  padding-top: 18rpx;
}

.source-title {
  color: rgba(35, 119, 93, 0.72);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 32rpx;
  margin-bottom: 8rpx;
}

.source-item {
  align-items: flex-start;
  display: flex;
  gap: 16rpx;
  margin-top: 10rpx;
}

.source-main {
  flex: 1;
  min-width: 0;
}

.source-name {
  color: rgba(31, 41, 55, 0.7);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.source-note,
.uncertainty-note {
  color: rgba(31, 41, 55, 0.46);
  font-size: 22rpx;
  line-height: 34rpx;
  margin-top: 4rpx;
  white-space: pre-wrap;
}

.source-open {
  background: rgba(61, 189, 147, 0.1);
  border: 1rpx solid rgba(61, 189, 147, 0.2);
  border-radius: 999rpx;
  color: #23775D;
  flex: 0 0 82rpx;
  font-size: 22rpx;
  font-weight: 700;
  height: 46rpx;
  line-height: 44rpx;
  margin: 0;
  padding: 0;
  width: 82rpx;
}

.source-open::after {
  border: none;
}

.uncertainty-note {
  background: rgba(248, 247, 244, 0.78);
  border-radius: 8rpx;
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
}

.verification-card {
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(61, 189, 147, 0.18);
  border-radius: 8rpx;
  box-sizing: border-box;
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
}

.verification-label {
  color: #23775D;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 32rpx;
  margin-bottom: 8rpx;
}

.verification-text {
  color: rgba(31, 41, 55, 0.62);
  font-size: 24rpx;
  line-height: 38rpx;
  margin-top: 6rpx;
  white-space: pre-wrap;
}

.verification-fields {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.verification-field {
  background: rgba(61, 189, 147, 0.1);
  border-radius: 999rpx;
  color: #23775D;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 32rpx;
  padding: 6rpx 16rpx;
}

.explore-question {
  background: rgba(61, 189, 147, 0.08);
  border-radius: 8rpx;
  margin-top: 30rpx;
  padding: 24rpx 26rpx;
}

.question-text {
  color: #1F2937;
  font-size: 31rpx;
  line-height: 52rpx;
  white-space: pre-wrap;
}

.thinking {
  align-items: center;
  display: flex;
  flex-direction: column;
  padding: 34rpx 0 46rpx;
}

.thinking-leaf {
  animation: leaf-breathe 2400ms ease-in-out infinite;
  height: 72rpx;
  transform-origin: 50% 84%;
  width: 72rpx;
}

.thinking-text {
  color: rgba(31, 41, 55, 0.5);
  font-size: 26rpx;
  line-height: 38rpx;
  margin-top: 16rpx;
}

.thinking-time {
  color: #23775D;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
  margin-top: 14rpx;
}

.composer {
  background: #F8F7F4;
  flex-shrink: 0;
  padding-top: 12rpx;
}

.composer-bar {
  align-items: flex-end;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(61, 189, 147, 0.26);
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  gap: 12rpx;
  min-height: 76rpx;
  padding: 8rpx 8rpx 8rpx 22rpx;
  width: 100%;
}

.input {
  background: transparent;
  border: none;
  box-sizing: border-box;
  color: #1F2937;
  flex: 1;
  font-size: 27rpx;
  line-height: 40rpx;
  max-height: 168rpx;
  min-height: 48rpx;
  overflow-y: auto;
  padding: 10rpx 0 8rpx;
  width: auto;
}

.input-placeholder {
  color: rgba(31, 41, 55, 0.34);
}

.send {
  align-items: center;
  background: rgba(61, 189, 147, 0.12);
  align-self: center;
  border-radius: 50%;
  box-sizing: border-box;
  color: #23775D;
  display: flex;
  flex: 0 0 60rpx;
  font-size: 25rpx;
  font-weight: 700;
  height: 60rpx;
  justify-content: center;
  line-height: 60rpx;
  margin: 0 28rpx 0 0;
  min-width: 0;
  padding: 0;
  width: 60rpx;
}

.send[disabled] {
  background: rgba(61, 189, 147, 0.08);
  color: rgba(35, 119, 93, 0.42);
}

.send::after {
  border: none;
}

.send-icon {
  height: 34rpx;
  opacity: 1;
  width: 34rpx;
}

.session-mask {
  align-items: flex-end;
  background: rgba(31, 41, 55, 0.2);
  bottom: 0;
  display: flex;
  left: 0;
  opacity: 0;
  pointer-events: none;
  position: fixed;
  right: 0;
  top: 0;
  transition: opacity 300ms ease;
  z-index: 30;
}

.session-mask-show {
  opacity: 1;
  pointer-events: auto;
}

.session-panel {
  background: #FFFDF8;
  border-radius: 28rpx 28rpx 0 0;
  box-sizing: border-box;
  max-height: 76vh;
  opacity: 0;
  padding: 34rpx 32rpx calc(28rpx + env(safe-area-inset-bottom));
  transform: translateY(72rpx);
  transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1), opacity 260ms ease;
  width: 100%;
}

.session-panel-show {
  opacity: 1;
  transform: translateY(0);
}

.session-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.session-title {
  color: #1F2937;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 50rpx;
}

.session-subtitle {
  color: rgba(31, 41, 55, 0.5);
  font-size: 24rpx;
  line-height: 34rpx;
  margin-top: 4rpx;
}

.session-empty {
  color: rgba(31, 41, 55, 0.48);
  font-size: 26rpx;
  line-height: 44rpx;
  padding: 60rpx 0;
  text-align: center;
}

.session-list {
  max-height: 56vh;
}

.session-item {
  border: 1rpx solid rgba(31, 41, 55, 0.07);
  border-radius: 8rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
  padding: 24rpx 26rpx;
}

.session-active {
  background: rgba(61, 189, 147, 0.08);
  border-color: rgba(61, 189, 147, 0.26);
}

.session-item-title {
  color: #1F2937;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.session-item-summary {
  color: rgba(31, 41, 55, 0.62);
  font-size: 25rpx;
  line-height: 40rpx;
  margin-top: 8rpx;
}

.session-item-date {
  color: rgba(31, 41, 55, 0.38);
  font-size: 22rpx;
  line-height: 32rpx;
  margin-top: 10rpx;
}

@keyframes leaf-breathe {
  0% {
    opacity: 0.76;
    transform: scale(0.94) rotate(-2deg);
  }

  50% {
    opacity: 1;
    transform: scale(1.08) rotate(3deg);
  }

  100% {
    opacity: 0.76;
    transform: scale(0.94) rotate(-2deg);
  }
}
