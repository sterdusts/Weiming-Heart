page {
  min-height: 100%;
  background: #F8F7F4;
}

.page {
  box-sizing: border-box;
  color: #1F2937;
  min-height: 100vh;
  padding: 52rpx 34rpx calc(36rpx + env(safe-area-inset-bottom));
}

.header {
  margin-bottom: 38rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 58rpx;
}

.subtitle {
  color: rgba(31, 41, 55, 0.56);
  font-size: 26rpx;
  line-height: 40rpx;
  margin-top: 8rpx;
  max-width: 610rpx;
}

.empty {
  align-items: center;
  display: flex;
  flex-direction: column;
  padding-top: 180rpx;
  text-align: center;
}

.empty-leaf {
  height: 98rpx;
  opacity: 0.62;
  width: 98rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 46rpx;
  margin-top: 28rpx;
}

.empty-subtitle {
  color: rgba(31, 41, 55, 0.54);
  font-size: 26rpx;
  line-height: 42rpx;
  margin-top: 8rpx;
}

.history-card {
  background: rgba(255, 253, 248, 0.86);
  border: 1rpx solid rgba(31, 41, 55, 0.06);
  border-radius: 8rpx;
  box-shadow: 0 14rpx 34rpx rgba(31, 41, 55, 0.045);
  box-sizing: border-box;
  margin-bottom: 18rpx;
  padding: 28rpx 30rpx;
}

.history-card-active {
  background: rgba(61, 189, 147, 0.08);
  border-color: rgba(61, 189, 147, 0.28);
}

.record-meta {
  align-items: center;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.record-date {
  color: rgba(31, 41, 55, 0.42);
  font-size: 22rpx;
  line-height: 32rpx;
}

.record-current {
  background: rgba(61, 189, 147, 0.13);
  border: 1rpx solid rgba(61, 189, 147, 0.25);
  border-radius: 999rpx;
  color: #23775D;
  flex: 0 0 auto;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 34rpx;
  padding: 0 16rpx;
}

.record-title {
  color: #1F2937;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 46rpx;
  margin-top: 8rpx;
}

.record-summary {
  color: rgba(31, 41, 55, 0.64);
  font-size: 26rpx;
  line-height: 42rpx;
  margin-top: 8rpx;
}

.record-action {
  color: #23775D;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
  margin-top: 18rpx;
}

.detail-mask {
  align-items: flex-end;
  background: rgba(31, 41, 55, 0.22);
  bottom: 0;
  display: flex;
  left: 0;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 10;
}

.detail-panel {
  background: #FFFDF8;
  border-radius: 28rpx 28rpx 0 0;
  box-sizing: border-box;
  max-height: 78vh;
  overflow-y: auto;
  padding: 40rpx 34rpx calc(34rpx + env(safe-area-inset-bottom));
  width: 100%;
}

.detail-date {
  color: rgba(31, 41, 55, 0.42);
  font-size: 23rpx;
  line-height: 34rpx;
}

.detail-title {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 54rpx;
  margin-top: 8rpx;
}

.detail-summary {
  color: rgba(31, 41, 55, 0.66);
  font-size: 28rpx;
  line-height: 46rpx;
  margin-top: 14rpx;
}

.detail-section {
  margin-top: 32rpx;
}

.section-label {
  color: #23775D;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
  margin-bottom: 12rpx;
}

.section-title {
  color: #1F2937;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 44rpx;
  margin-bottom: 8rpx;
}

.section-text {
  color: rgba(31, 41, 55, 0.72);
  font-size: 28rpx;
  line-height: 48rpx;
  margin-top: 8rpx;
  white-space: pre-wrap;
}

.section-question {
  background: rgba(61, 189, 147, 0.08);
  border-radius: 8rpx;
  color: #1F2937;
  font-size: 28rpx;
  line-height: 48rpx;
  margin-top: 16rpx;
  padding: 20rpx 22rpx;
  white-space: pre-wrap;
}

.close-button {
  background: #3DBD93;
  border-radius: 8rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  height: 82rpx;
  line-height: 82rpx;
  margin: 34rpx 0 0;
  width: 100%;
}

.close-button::after {
  border: none;
}
