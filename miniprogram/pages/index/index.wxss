page {
  min-height: 100%;
  background: #F8F7F4;
}

.page {
  box-sizing: border-box;
  color: #1F2937;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 56rpx 36rpx calc(28rpx + env(safe-area-inset-bottom));
  opacity: 1;
  transition: opacity 460ms ease, transform 460ms ease;
}

.page-leaving {
  opacity: 0;
  transform: translateY(-12rpx);
}

.landing-page {
  min-height: 100vh;
  overflow: hidden;
  padding: 0;
}

.landing-screen {
  align-items: center;
  box-sizing: border-box;
  display: flex;
  flex: 1;
  flex-direction: column;
  min-height: 100vh;
  opacity: 0;
  padding: 58rpx 36rpx calc(42rpx + env(safe-area-inset-bottom));
  position: relative;
  transform: translateY(20rpx) scale(0.99);
  transition: opacity 420ms ease, transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
  will-change: opacity, transform;
}

.landing-entering .landing-screen {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.landing-starting .landing-screen {
  opacity: 0;
  transform: translateY(-20rpx) scale(0.985);
}

.interview-screen {
  box-sizing: border-box;
  display: flex;
  flex: 1;
  flex-direction: column;
  min-height: 0;
  opacity: 0;
  transform: translateY(24rpx);
  transition: opacity 520ms ease, transform 520ms cubic-bezier(0.22, 1, 0.36, 1);
  width: 100%;
  will-change: opacity, transform;
}

.interview-screen-show {
  opacity: 1;
  transform: translateY(0);
}

.interview-returning .interview-screen {
  opacity: 0;
  transform: translateY(22rpx) scale(0.99);
}

.landing-title-group {
  align-items: center;
  display: flex;
  flex-direction: column;
  text-align: center;
  width: 100%;
  z-index: 1;
}

.landing-title {
  color: #1F2937;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 56rpx;
  max-width: 560rpx;
}

.landing-subtitle {
  color: rgba(31, 41, 55, 0.58);
  font-size: 23rpx;
  line-height: 34rpx;
  margin-top: 6rpx;
}

.landing-profile-card {
  align-items: center;
  display: flex;
  flex-direction: column;
  margin-top: 24rpx;
}

.landing-profile {
  background: rgba(61, 189, 147, 0.08);
  border: 1rpx solid rgba(61, 189, 147, 0.2);
  border-radius: 999rpx;
  color: #23775D;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 54rpx;
  padding: 14rpx 42rpx;
}

.profile-card-hint {
  color: rgba(31, 41, 55, 0.42);
  font-size: 22rpx;
  line-height: 32rpx;
  margin-top: 10rpx;
}

.tap-hint {
  color: rgba(35, 119, 93, 0.68);
  font-size: 25rpx;
  font-weight: 600;
  line-height: 36rpx;
  margin-top: 126rpx;
  z-index: 1;
}

.hero-sprout-wrap {
  align-items: center;
  display: flex;
  flex: 1;
  justify-content: center;
  min-height: 0;
  width: 100%;
}

.hero-sprout {
  animation: sproutHeroBreath 4.8s ease-in-out infinite;
  height: 430rpx;
  opacity: 0.9;
  transform-origin: 50% 92%;
  width: 430rpx;
}

.landing-entry-row {
  align-items: center;
  display: flex;
  gap: 14rpx;
  justify-content: center;
  margin-bottom: 34rpx;
  max-width: 620rpx;
  width: 88%;
  z-index: 2;
}

.landing-explore-entry {
  align-items: center;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(61, 189, 147, 0.26);
  border-radius: 999rpx;
  box-shadow: 0 14rpx 34rpx rgba(31, 41, 55, 0.04);
  box-sizing: border-box;
  display: flex;
  flex: 1;
  height: 76rpx;
  justify-content: space-between;
  padding: 0 18rpx 0 30rpx;
  transition: opacity 220ms ease, transform 220ms ease, border-color 220ms ease;
  min-width: 0;
}

.landing-explore-entry:active {
  border-color: rgba(61, 189, 147, 0.42);
  opacity: 0.82;
  transform: translateY(2rpx) scale(0.992);
}

.explore-entry-placeholder {
  color: rgba(31, 41, 55, 0.38);
  flex: 1;
  font-size: 25rpx;
  line-height: 36rpx;
  overflow: hidden;
  text-align: left;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.explore-entry-action {
  align-items: center;
  background: rgba(61, 189, 147, 0.12);
  border-radius: 999rpx;
  color: #23775D;
  display: flex;
  flex-shrink: 0;
  font-size: 23rpx;
  font-weight: 700;
  height: 50rpx;
  justify-content: center;
  margin-left: 16rpx;
  width: 82rpx;
}

.landing-history-button {
  align-items: center;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(61, 189, 147, 0.28);
  border-radius: 999rpx;
  box-shadow: 0 14rpx 32rpx rgba(31, 41, 55, 0.055);
  box-sizing: border-box;
  display: flex;
  flex: 0 0 76rpx;
  height: 76rpx;
  justify-content: center;
  line-height: 76rpx;
  margin: 0;
  min-width: 0;
  padding: 0;
  transition: opacity 220ms ease, transform 220ms ease;
  width: 76rpx;
}

.landing-history-button:active {
  opacity: 0.82;
  transform: translateY(2rpx) scale(0.96);
}

.landing-history-icon {
  height: 38rpx;
  width: 38rpx;
}

.landing-quote {
  color: rgba(31, 41, 55, 0.48);
  font-size: 23rpx;
  line-height: 36rpx;
  text-align: center;
  z-index: 1;
}

.quote-line {
  letter-spacing: 0;
}

.quote-source {
  color: rgba(31, 41, 55, 0.38);
  font-size: 21rpx;
  line-height: 32rpx;
  margin-top: 8rpx;
}

.top {
  flex-shrink: 0;
}

.hero-section {
  align-items: flex-start;
  display: flex;
  justify-content: space-between;
  position: relative;
}

.hero-text {
  flex: 1;
  min-width: 0;
  padding-right: 150rpx;
}

.sprout-wrap {
  flex-shrink: 0;
  height: 136rpx;
  margin-right: 12rpx;
  margin-top: 4rpx;
  position: relative;
  width: 136rpx;
}

.back-home-button {
  align-items: center;
  background: rgba(61, 189, 147, 0.12);
  border: 1rpx solid rgba(61, 189, 147, 0.24);
  border-radius: 999rpx;
  box-sizing: border-box;
  color: rgba(35, 119, 93, 0.72);
  display: flex;
  flex-shrink: 0;
  height: 58rpx;
  justify-content: center;
  margin: 0;
  position: absolute;
  right: -6rpx;
  top: 82rpx;
  width: 58rpx;
  z-index: 2;
}

.back-home-button:active {
  opacity: 0.78;
  transform: scale(0.96);
}

.back-home-icon {
  height: 31rpx;
  width: 31rpx;
}

.brand {
  color: #1F2937;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 58rpx;
}

.tagline {
  color: rgba(31, 41, 55, 0.58);
  font-size: 26rpx;
  line-height: 40rpx;
  margin-top: 8rpx;
}

.sprout-decoration {
  display: block;
  height: 124rpx;
  margin: 0;
  opacity: 0.72;
  transform-origin: 50% 100%;
  width: 124rpx;
  animation: sproutBreath 3.8s ease-in-out infinite;
}

.home {
  flex: 1;
  padding: 56rpx 0 28rpx;
}

.home-label {
  color: rgba(31, 41, 55, 0.5);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 38rpx;
  margin-bottom: 22rpx;
}

.profile-card {
  background: #FFFDF8;
  border: 1rpx solid rgba(31, 41, 55, 0.06);
  border-radius: 8rpx;
  box-shadow: 0 18rpx 42rpx rgba(31, 41, 55, 0.05);
  box-sizing: border-box;
  padding: 42rpx 36rpx;
}

.profile-keyword {
  color: #1F2937;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.profile-sub {
  color: #6B7280;
  font-size: 26rpx;
  line-height: 38rpx;
  margin-top: 10rpx;
}

.profile-date {
  color: rgba(31, 41, 55, 0.46);
  font-size: 24rpx;
  line-height: 34rpx;
  margin-top: 42rpx;
}

.home-actions {
  margin-top: 28rpx;
}

.home-button {
  background: #FFFFFF;
  border: 1rpx solid rgba(61, 189, 147, 0.24);
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #23775D;
  font-size: 30rpx;
  font-weight: 700;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0 0 16rpx;
  width: 100%;
}

.home-button::after {
  border: none;
}

.primary-home-button {
  background: #3DBD93;
  color: #FFFFFF;
}

.quiet-home-button {
  background: transparent;
  border-color: transparent;
  color: rgba(31, 41, 55, 0.58);
}

.history {
  margin-top: 42rpx;
}

.history-title {
  color: rgba(31, 41, 55, 0.5);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 38rpx;
  margin-bottom: 18rpx;
}

.history-item {
  border-bottom: 1rpx solid rgba(31, 41, 55, 0.08);
  padding: 22rpx 4rpx;
}

.history-date {
  color: rgba(31, 41, 55, 0.42);
  font-size: 22rpx;
  line-height: 32rpx;
}

.history-name {
  color: #1F2937;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 42rpx;
  margin-top: 6rpx;
}

.history-summary {
  color: rgba(31, 41, 55, 0.62);
  font-size: 26rpx;
  line-height: 42rpx;
  margin-top: 6rpx;
}

.stage {
  box-sizing: border-box;
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: flex-start;
  min-height: 0;
  padding: 64rpx 0 32rpx;
  transition: padding 420ms ease;
}

.stage-reflecting {
  padding-top: 78rpx;
}

.stage-reflecting .progress {
  margin-bottom: 30rpx;
}

.progress {
  margin-bottom: 42rpx;
  transition: margin-bottom 420ms ease;
}

.progress-text {
  color: rgba(31, 41, 55, 0.48);
  font-size: 24rpx;
  line-height: 34rpx;
}

.progress-line {
  background: rgba(61, 189, 147, 0.16);
  border-radius: 999rpx;
  height: 6rpx;
  margin-top: 16rpx;
  overflow: hidden;
  width: 100%;
}

.progress-line-active {
  background: #3DBD93;
  border-radius: 999rpx;
  height: 100%;
}

.question-card {
  background: #FFFFFF;
  border: 1rpx solid rgba(31, 41, 55, 0.06);
  border-radius: 8rpx;
  box-shadow: 0 18rpx 42rpx rgba(31, 41, 55, 0.05);
  box-sizing: border-box;
  padding: 42rpx 38rpx 42rpx;
}

.card-slot {
  min-height: 720rpx;
  position: relative;
}

.interview-card {
  opacity: 0;
  transform: translateY(24rpx) scale(0.99);
  transition: opacity 560ms ease, transform 560ms cubic-bezier(0.22, 1, 0.36, 1);
  will-change: opacity, transform;
}

.interview-card-show {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.interview-card-leaving {
  opacity: 0;
  transform: translateY(-18rpx) scale(0.985);
}

.question-step {
  color: #3DBD93;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
  margin-bottom: 12rpx;
}

.question-title {
  color: #1F2937;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 58rpx;
}

.question-tip {
  color: rgba(31, 41, 55, 0.62);
  font-size: 27rpx;
  line-height: 44rpx;
  margin-top: 22rpx;
}

.field-list {
  margin-top: 34rpx;
}

.field-item {
  margin-top: 22rpx;
}

.field-item:first-child {
  margin-top: 0;
}

.field-label,
.open-question {
  color: rgba(31, 41, 55, 0.62);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
  margin-bottom: 10rpx;
}

.field-input {
  background: rgba(248, 247, 244, 0.72);
  border: 1rpx solid rgba(31, 41, 55, 0.08);
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #1F2937;
  font-size: 29rpx;
  height: 82rpx;
  line-height: 82rpx;
  padding: 0 24rpx;
  width: 100%;
}

.input-placeholder,
.answer-placeholder {
  color: rgba(31, 41, 55, 0.34);
}

.option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 34rpx;
}

.option-item {
  background: rgba(248, 247, 244, 0.86);
  border: 1rpx solid rgba(31, 41, 55, 0.08);
  border-radius: 8rpx;
  box-sizing: border-box;
  color: rgba(31, 41, 55, 0.72);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 40rpx;
  min-height: 74rpx;
  padding: 16rpx 24rpx;
}

.option-selected {
  background: rgba(61, 189, 147, 0.14);
  border-color: rgba(61, 189, 147, 0.44);
  color: #23775D;
}

.slider-block {
  margin-top: 42rpx;
}

.slider-value {
  color: #1F2937;
  font-size: 64rpx;
  font-weight: 700;
  line-height: 82rpx;
  text-align: center;
}

.slider-label-row {
  color: rgba(31, 41, 55, 0.56);
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
  line-height: 34rpx;
  margin-top: 4rpx;
}

.slider-text {
  background: rgba(61, 189, 147, 0.08);
  border-radius: 8rpx;
  color: #23775D;
  font-size: 26rpx;
  line-height: 42rpx;
  margin-top: 26rpx;
  padding: 20rpx 24rpx;
  text-align: center;
}

.open-block {
  margin-top: 34rpx;
}

.open-answer {
  background: rgba(248, 247, 244, 0.72);
  border: 1rpx solid rgba(31, 41, 55, 0.08);
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #1F2937;
  font-size: 30rpx;
  line-height: 46rpx;
  min-height: 176rpx;
  padding: 26rpx 28rpx;
  width: 100%;
}

.reflection-card {
  background: #FFFFFF;
  border: 1rpx solid rgba(61, 189, 147, 0.16);
  border-radius: 8rpx;
  box-shadow: 0 18rpx 42rpx rgba(31, 41, 55, 0.05);
  box-sizing: border-box;
  opacity: 0;
  padding: 48rpx 40rpx;
  transform: translateY(24rpx) scale(0.985);
  transition: opacity 460ms ease, transform 460ms cubic-bezier(0.22, 1, 0.36, 1);
  will-change: opacity, transform;
}

.reflection-card-show {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.reflection-label {
  color: #3DBD93;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0;
  line-height: 34rpx;
  margin-bottom: 22rpx;
}

.reflection-text {
  color: #1F2937;
  font-size: 38rpx;
  font-weight: 600;
  line-height: 58rpx;
}

.bottom {
  flex-shrink: 0;
  opacity: 1;
  transform: translateY(0);
  transition: opacity 420ms ease, transform 420ms ease;
}

.bottom-hidden {
  opacity: 0;
  pointer-events: none;
  transform: translateY(16rpx);
}

.next-button {
  background: #3DBD93;
  border-radius: 8rpx;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  height: 96rpx;
  line-height: 96rpx;
  margin: 0;
  width: 100%;
}

.next-button::after {
  border: none;
}

.next-button:active {
  background: #34ab84;
}

.next-button[disabled] {
  background: #A9DEC8;
  color: rgba(255, 255, 255, 0.9);
}

@keyframes sproutBreath {
  0% {
    opacity: 0.62;
    transform: scale(1) rotate(-1deg);
  }

  50% {
    opacity: 0.82;
    transform: scale(1.06) rotate(1.5deg);
  }

  100% {
    opacity: 0.62;
    transform: scale(1) rotate(-1deg);
  }
}

@keyframes sproutHeroBreath {
  0% {
    opacity: 0.78;
    transform: scale(0.96) rotate(-1deg);
  }

  50% {
    opacity: 1;
    transform: scale(1.04) rotate(1.2deg);
  }

  100% {
    opacity: 0.78;
    transform: scale(0.96) rotate(-1deg);
  }
}
