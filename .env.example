# Copy these values into the WeChat Cloud Function environment variables.
# This file is documentation only; the mini program does not load it directly.

# Required for cloudfunctions/deepseekChat.
DEEPSEEK_API_KEY=

# Optional. Used by the web-search helper when available.
JINA_API_KEY=

# Optional runtime tuning.
DEEPSEEK_TIMEOUT=180000
SEARCH_TIMEOUT=15000
SEARCH_RESULT_LIMIT=5000
